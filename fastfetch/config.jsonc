{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    { "type": "display", "key": "Resolution", "format": "{width}x{height} @ {refresh-rate} Hz" },
    "wm",
    { "type": "terminal", "format": "{pretty-name}" },
    "cpu",
    "gpu",
    "memory",
    "break",
    "colors"
  ]
}
